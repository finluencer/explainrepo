{
  "name": "explainrepo",
  "version": "1.0.0",
  "description": "Understand any codebase instantly — map structure, trace flow, find logic",
  "author": "finluencer",
  "repository": {
    "type": "git",
    "url": "https://github.com/finluencer/explainrepo.git"
  },
  "main": "bin/cli.js",
  "type": "commonjs",
  "engines": {
    "node": ">=16.0.0"
  },
  "keywords": [
    "cli",
    "codebase",
    "developer-tools",
    "code-search",
    "ast",
    "dependency-graph"
  ],
  "scripts": {
    "start": "node bin/cli.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "bin": {
    "explainrepo": "./bin/cli.js"
  },
  "license": "MIT",
  "dependencies": {
    "@babel/parser": "^7.29.2",
    "@babel/traverse": "^7.29.0",
    "commander": "^14.0.3",
    "ignore": "^7.0.5"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.1",
    "nodemon": "^3.1.14",
    "vitest": "^4.1.1"
  }
}
